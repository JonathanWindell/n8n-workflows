    {
      "parameters": {
        "jsCode": "const skillsList = $('Aggregate Skills').first().json.Skills_Keywords.map(i => String(i[\"Skill Keywords\"] || \"\").toLowerCase().trim());\nconst timeList = $('Aggregate Time').first().json.Time_Keywords.map(i => String(i[\"Time\"] || \"\").toLowerCase().trim());\nconst placeList = $('Aggregate Place of Work').first().json.PlaceofWork_Keywords.map(i => String(i[\"Remote\"] || \"\").toLowerCase().trim());\nconst rolesList = $('Aggregate Roles').first().json.Roles_Keywords.map(i => String(i[\"Roles\"] || \"\").toLowerCase().trim());\n\nconst loggedJobsData = $('Aggregate Logged Jobs').first().json.Logged_Jobs || [];\nconst loggedUrls = loggedJobsData.map(j => String(j[\"Found Jobs\"] || \"\").trim());\n\nreturn $input.all().filter(item => {\n  const job = item.json;\n\n  const currentUrl = (job.url || job.application_url || \"\").trim();\n  if (loggedUrls.includes(currentUrl)) {\n    return false;\n  }\n\n  const content = (\n    (job.position || job.title || \"\") + \" \" + \n    (job.description || \"\") + \" \" + \n    (job.tags ? job.tags.join(\" \") : \"\")\n  ).toLowerCase();\n\n  const isRemote = placeList.some(word => word !== \"\" && content.includes(word));\n  const isPartTime = timeList.some(word => word !== \"\" && content.includes(word));\n\n  // This you have to change if not correct search words. \n  if (isRemote && isPartTime) {\n    let score = 0;\n    \n    rolesList.forEach(word => { if (word !== \"\" && content.includes(word)) score += 10; });\n    skillsList.forEach(word => { if (word !== \"\" && content.includes(word)) score += 5; });\n\n    item.json.match_score = score;\n    return true; \n  }\n\n  return false; \n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
