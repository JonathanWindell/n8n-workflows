    {
      "parameters": {
        "sendTo": "din.epost@example.com",
        "subject": "Daily Job Search",
        "message": "=<!DOCTYPE html>\n<html>\n<head>\n<style>\n  body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f0f4f8; color: #333; margin: 0; padding: 20px; }\n  .container { max-width: 600px; margin: auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }\n  .header { background: #1a73e8; color: white; padding: 30px 20px; text-align: center; }\n  .header h1 { margin: 0; font-size: 24px; letter-spacing: 1px; }\n  .job-card { padding: 25px; border-bottom: 1px solid #edf2f7; position: relative; }\n  .job-card:last-child { border-bottom: none; }\n  .nomad-badge { background: #fff8e1; color: #b45309; padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: bold; float: right; border: 1px solid #fef3c7; }\n  .title { font-size: 19px; margin: 0 0 5px 0; color: #1a73e8; font-weight: 700; line-height: 1.2; }\n  .company { color: #64748b; font-size: 15px; font-weight: 500; margin-bottom: 15px; display: block; }\n  .stats-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 15px; }\n  .stat-pill { background: #f1f5f9; color: #475569; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 500; }\n  .summary { font-size: 14px; line-height: 1.6; color: #334155; margin-bottom: 20px; background: #f8fafc; padding: 15px; border-radius: 8px; }\n  .skill-container { margin-bottom: 20px; }\n  .skill-tag { display: inline-block; background: #e0e7ff; color: #4338ca; padding: 2px 8px; border-radius: 4px; font-size: 11px; margin: 0 4px 4px 0; font-weight: 500; }\n  .btn { display: block; text-align: center; background: #1a73e8; color: white !important; padding: 12px; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 14px; transition: background 0.2s; }\n  .footer { padding: 20px; font-size: 12px; color: #94a3b8; text-align: center; background: #f8fafc; }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <div class=\"header\">\n      <h1>Job Possibilites </h1>\n    </div>\n\n    {{ $json.data.map(item => {\n      const job = item.output;\n      return `\n      <div class=\"job-card\">\n        <span class=\"nomad-badge\">Nomad Score: ${job.nomad_score}</span>\n        <div class=\"title\">${job.job_title}</div>\n        <span class=\"company\">${job.company_name}</span>\n\n        <div class=\"stats-grid\">\n          <span class=\"stat-pill\"> ${job.work_hours}</span>\n          <span class=\"stat-pill\"> ${job.location_type}</span>\n          <span class=\"stat-pill\"> ${job.salary_info}</span>\n          <span class=\"stat-pill\"> ${job.geographical_requirements}</span>\n        </div>\n\n        <div class=\"summary\">\n          ${job.summary_sv}\n        </div>\n\n        <div class=\"skill-container\">\n          ${job.key_skills ? job.key_skills.map(skill => `<span class=\"skill-tag\">${skill}</span>`).join('') : ''}\n        </div>\n\n        <a href=\"${job.application_url}\" class=\"btn\">Gå till ansökan</a>\n      </div>\n      `;\n    }).join('') }}\n\n    <div class=\"footer\">\n      Found via personal n8n-automation.<br>\n    </div>\n  </div>\n</body>\n</html>",
        "options": {}
      },
