    {
      "parameters": {
        "jsCode": "const aiOutput = $(\"Analyze Receipt\").item.json;\nconst exchangeData = $(\"Get Currencies\").item.json;\n\nlet rawText = aiOutput.content.parts[0].text;\n\n// Use \\x60 to safely represent backticks in JSON templates\nconst cleanJson = rawText.replace(/\\x60\\x60\\x60json/g, \"\").replace(/\\x60\\x60\\x60/g, \"\").trim();\n\ntry {\n  const receipt = JSON.parse(cleanJson);\n  const eurToSek = exchangeData.rates.SEK;\n  \n  let finalAmountSek = receipt.amount;\n  if (receipt.currency.toUpperCase() === 'EUR') {\n    finalAmountSek = receipt.amount * eurToSek;\n  }\n\n  return {\n    date: receipt.date,\n    merchant: receipt.merchant,\n    category: receipt.category,\n    amount_orig: receipt.amount,\n    currency_orig: receipt.currency,\n    amount_sek: Math.round(finalAmountSek * 100) / 100,\n    exchange_rate: eurToSek,\n    month: DateTime.fromISO(receipt.date).toFormat('yyyy-MM')\n  };\n} catch (e) {\n  return {\n    error: \"Could not interpret JSON from AI\",\n    raw_text: cleanJson\n  };\n}"
      },
