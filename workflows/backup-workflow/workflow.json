      },
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3.2,
      "position": [-48, 272],
      "id": "154adb58-1a28-4c26-a7be-560c6ca6b613",
      "name": "Merge Github & n8n "
    },
    {
      "parameters": {
        "jsCode": "const localWorkflow = items[0].json.Local; \nconst remoteWorkflow = items[0].json.Remote; \n\nif (!remoteWorkflow || Object.keys(remoteWorkflow).length === 0) {\n    return {\n        json: {\n            isIdentical: false,\n            status: \"New\",\n            fileContent: localWorkflow\n        }\n    };\n}\n\nfunction sortObjectKeys(obj) {\n    if (typeof obj !== 'object' || obj === null) {\n        return obj;\n    }\n    if (Array.isArray(obj)) {\n        return obj.map(sortObjectKeys);\n    }\n    return Object.keys(obj)\n        .sort()\n        .reduce((result, key) => {\n            result[key] = sortObjectKeys(obj[key]);\n            return result;\n        }, {});\n}\n\nfunction cleanWorkflow(workflow) {\n    if (!workflow) return {};\n\n    const clean = JSON.parse(JSON.stringify(workflow));\n\n    const keysToRemove = ['updatedAt', 'createdAt', 'id', 'versionId', 'active', 'name', 'settings', 'pinData', 'meta', 'tags'];\n    keysToRemove.forEach(key => delete clean[key]);\n\n    if (clean.nodes && Array.isArray(clean.nodes)) {\n        clean.nodes.forEach(node => {\n            delete node.position;\n            delete node.id;\n        });\n\n        clean.nodes.sort((a, b) => {\n            const nameA = (a.name || \"\").toUpperCase();\n            const nameB = (b.name || \"\").toUpperCase();\n            if (nameA < nameB) return -1;\n            if (nameA > nameB) return 1;\n            return 0;\n        });\n    }\n    \n    return clean;\n}\n\nlet cleanLocal = cleanWorkflow(localWorkflow);\nlet cleanRemote = cleanWorkflow(remoteWorkflow);\n\ncleanLocal = sortObjectKeys(cleanLocal);\ncleanRemote = sortObjectKeys(cleanRemote);\n\nconst isIdentical = JSON.stringify(cleanLocal) === JSON.stringify(cleanRemote);\n\nreturn {\n    json: {\n        status: isIdentical ? \"Synced\" : \"Changed\",\n        fileContent: localWorkflow, \n        sha: remoteWorkflow ? remoteWorkflow.sha : null \n    }\n};"
      },
